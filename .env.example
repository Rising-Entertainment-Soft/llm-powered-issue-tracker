# SQLite local file
DATABASE_URL="file:./dev.db"

# Auth.js
AUTH_SECRET="change-me-to-a-random-32+-char-string"
AUTH_TRUST_HOST="true"

# Gemini
GEMINI_API_KEY="paste-your-gemini-api-key-here"

# Chatwork (エスカレーション用 bot)
# 未設定なら Chatwork 投稿機能は無効化される。
# トークン: Chatwork設定 → APIトークン (bot アカウント推奨)
# ルーム ID: 投稿先ルームの URL "chatwork.com/#!rid12345" から取得
CHATWORK_API_TOKEN=""
CHATWORK_ROOM_ID=""
# アプリの公開URL (Chatwork投稿内のチケットリンクに使う)
# 例: https://llm.rising.saltybullet.com
PUBLIC_APP_URL=""
